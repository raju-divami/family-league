# ──────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# .env is gitignored — never commit real secrets.
# ──────────────────────────────────────────────

# ── Database (PostgreSQL) ─────────────────────
DB_URL=jdbc:postgresql://localhost:5432/family_league
DB_USERNAME=postgres
DB_PASSWORD=your_db_password

# ── Hibernate ────────────────────────────────
# Dialect for PostgreSQL
HIBERNATE_DIALECT=org.hibernate.dialect.PostgreSQLDialect
# DDL strategy: use 'validate' in production, 'update' during development
HIBERNATE_DDL_AUTO=update

# ── JWT ───────────────────────────────────────
# Must be at least 256 bits (32 characters). Change before going to production.
JWT_SECRET=change-me-to-a-secure-random-256-bit-secret-key
# Access token lifetime in milliseconds (default: 24 hours)
JWT_EXPIRATION_MS=86400000
# Refresh token lifetime in milliseconds (default: 7 days)
JWT_REFRESH_EXPIRATION_MS=604800000

# ── Email (Gmail SMTP example) ────────────────
# For Gmail: enable 2FA and use an App Password, not your account password.
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your_gmail_address@gmail.com
MAIL_PASSWORD=your_gmail_app_password

# ── Scheduler ─────────────────────────────────
# How often the reminder job runs (milliseconds). Default: 15 minutes.
SCHEDULER_REMINDER_INTERVAL_MS=900000
# How many hours before lock time to start sending reminders. Default: 2 hours.
SCHEDULER_REMINDER_WINDOW_HOURS=2
